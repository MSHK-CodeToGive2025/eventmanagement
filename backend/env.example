# MongoDB Configuration
MONGODB_URI=

# Server Configuration
PORT=3001
NODE_ENV=production

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# CORS Configuration (for production)
# Primary frontend domain
CORS_ORIGIN=https://your-frontend-domain.com

# Additional CORS origins (comma-separated)
# ADDITIONAL_CORS_ORIGINS=https://www.your-domain.com,https://app.your-domain.com

# AWS ALB Domains (update these with your actual ALB DNS names)
# FRONTEND_ALB_DOMAIN=https://frontend-alb-632577121.ap-east-1.elb.amazonaws.com
# BACKEND_ALB_DOMAIN=https://backend-alb-1469776694.ap-east-1.elb.amazonaws.com

# Twilio Configuration (if using WhatsApp features)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
TWILIO_WHATSAPP_NUMBER=whatsapp:+1xxxxxxxxxxx

# Twilio WhatsApp Template Configuration
# Event reminder (8-var): zubin_foundation_event_reminder_v2
TWILIO_WHATSAPP_TEMPLATE_SID=HX6dcf16072c4b77b1513ef377de2c0879
# Event update / custom notification (5-var utility): zubin_foundation_event_update_v2
TWILIO_WHATSAPP_EVENT_UPDATE_TEMPLATE_SID=HX1fc0085538023f4de77d3d3cce079387
# Marketing template (2-var) - used for reminder custom mode fallback
TWILIO_WHATSAPP_MARKETING_TEMPLATE_SID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

